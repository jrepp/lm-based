#!/usr/bin/env bash
set -euo pipefail

if [[ $# -ne 2 ]]; then
  echo "usage: model-service <model-slug> <port>" >&2
  exit 2
fi

slug="$1"
port="$2"
base_url="http://127.0.0.1:${port}"

current_model_id() {
  python3 - "$base_url" <<'PY'
import json
import sys
import urllib.error
import urllib.request

base_url = sys.argv[1]
try:
    with urllib.request.urlopen(base_url + "/v1/models", timeout=2.0) as response:
        data = json.loads(response.read())
except Exception:
    raise SystemExit(1)

models = data.get("data") or []
if not models:
    raise SystemExit(1)
print(models[0].get("id", ""))
PY
}

if current="$(current_model_id 2>/dev/null)"; then
  if [[ "${current}" == "${slug}" ]]; then
    echo "adopting existing ${slug} server on ${base_url}"
    while current="$(current_model_id 2>/dev/null)" && [[ "${current}" == "${slug}" ]]; do
      sleep 5
    done
    echo "existing ${slug} server disappeared or changed"
    exit 1
  fi
  echo "port ${port} is serving ${current}, not ${slug}" >&2
  exit 1
fi

exec ./run-server.py
