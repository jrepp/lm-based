# =============================================================================
# lm-based — environment configuration template
#
# Copy this file to .env and fill in your values.
# .env is gitignored; this file is committed as documentation.
#
# See docs/credentials.md for a full explanation of the credential model.
# =============================================================================

# -----------------------------------------------------------------------------
# Local model server
# -----------------------------------------------------------------------------

# Slug of the model to load at startup.
# Run `python download_model.py --list` to see available slugs.
MODEL_SLUG=gemma4-e2b-uncensored-aggressive-q4kp

# Server bind address and port (defaults shown).
# HOST=127.0.0.1
# PORT=8001


# -----------------------------------------------------------------------------
# ClawRouter / x402 proxy
# -----------------------------------------------------------------------------

# Port where the local x402 payment proxy listens (default: 8402).
# X402_PROXY_PORT=8402


# -----------------------------------------------------------------------------
# Cloud provider API keys
# -----------------------------------------------------------------------------
# Each key is OPTIONAL.
#
# If set AND the provider has a known direct endpoint → traffic goes direct.
# If not set → traffic is routed through the x402 proxy (pays via USDC).
#
# Run `python clawrouter_config.py --providers` to see the current routing
# decision for each provider based on your current environment.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
GEMINI_API_KEY=
GLM_API_KEY=
MINIMAX_API_KEY=


# -----------------------------------------------------------------------------
# Cloud provider base URL overrides (optional)
# -----------------------------------------------------------------------------
# Override the API base URL for any provider — useful for local proxies,
# compatible third-party endpoints, or API gateways.
#
# OPENAI_API_BASE=https://api.openai.com/v1
# ANTHROPIC_API_BASE=https://api.anthropic.com/v1
# DEEPSEEK_API_BASE=https://api.deepseek.com/v1
# XAI_API_BASE=https://api.x.ai/v1
# GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai
# GLM_API_BASE=
# MINIMAX_API_BASE=
